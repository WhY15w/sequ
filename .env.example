# dotenv config 
DOTENV_CONFIG_QUIET=true

# 游戏服务器地址
GAME_SERVER_HOST=175.24.235.221
# 游戏服务器端口
GAME_SERVER_PORT=1225

# 米米号 (必填)
SERVICE_ACCOUNT_ID=12345678
# 密码 (必填)
SERVICE_ACCOUNT_PASSWORD=your_password_here

# 是否打印发送/接收封包的回调日志（生产环境可设为 false 以减少日志输出）
LOG_CALLBACKS=true
# 是否记录完整的封包数据
LOG_FULL_PACKET=false
# 忽略不打印日志的命令ID列表 (使用 | 分隔)
IGNORED_CMD_IDS=8002|3452|2004|2001|41228|1002|2002
